# Whisper backend: ov | faster | whispercpp
WATCH_WHISPER=faster
# язык транскрипции (на языке оригинала, никакого перевода).
# ru — для русской речи: английские термины останутся терминами.
# НЕ ставь en на русское видео: Whisper начнёт подбирать похожие по звуку
# английские слова и вывернет смысл. auto рискует ошибиться на интро/музыке.
WATCH_LANG=ru
# потолок ширины кадра для vision-разбора (читаемость текста на слайдах/коде).
# Кадры не апскейлятся: видео уже этой ширины остаётся в родном разрешении.
WATCH_RES_OVERVIEW=1568
# плотность нарезки (кадр/сек) вместо жёсткого лимита — привязка к длине видео
WATCH_FPS=1
# порог pHash-дедупа (0..64): ниже = больше кадров, выше = агрессивнее схлопывание, 0 = выключить
WATCH_DEDUP_THRESHOLD=10

# ov (personal, Intel Arc / OpenVINO):
OV_PYTHON=
OV_MODEL=
OV_DEVICE=GPU

# faster (GitHub default, target NVIDIA/CUDA):
FW_MODEL=large-v3
FW_DEVICE=auto
FW_COMPUTE=auto

# whispercpp (option):
WHISPERCPP_BIN=
WHISPERCPP_MODEL=
